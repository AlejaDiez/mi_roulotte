---
import type { BaseProps } from "@models/props";

export interface Props extends BaseProps {}

const { id, class: cls } = Astro.props;
const currentDate = new Date();
---

<footer {id} class={cls}>
    <div class="content">
        <a
            href="https://x.com/intent/post?text=%23NosVemosEnLaCarretera%20%23MiRoulotte"
            target="_blank"
            rel="noopener noreferrer">
            <span class="text-normal">¡Nos vemos en la carretera!</span>
        </a>
        <nav>
            <a
                title="Correo electrónico"
                href="mailto:miroulotte@gmail.com?Subject=Contacto%20con%20Mi%20Roulotte"
                target="_blank"
                rel="noopener noreferrer">
                <i class="icon ibm-email"></i>
            </a>
            <a
                title="Instagram"
                href="https://www.instagram.com/miroulotte/"
                target="_blank"
                rel="noopener noreferrer">
                <i class="icon ibm-logo-instagram"></i>
            </a>
            <a
                title="YouTube"
                href="https://www.youtube.com/@miroulotte/"
                target="_blank"
                rel="noopener noreferrer">
                <i class="icon ibm-logo-youtube"></i>
            </a>
        </nav>
    </div>
    <div class="license">
        <span class="text-label">
            &copy; {currentDate.getFullYear()} Mi Roulotte · Todos los derechos reservados
        </span>
    </div>
</footer>

<style>
    footer {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: flex-start;
        cursor: default;
        padding: 0 var(--space-x);
        width: 100%;
        height: 8rem;
        -webkit-user-select: none;
        user-select: none;
    }

    .content {
        display: flex;
        flex-grow: 1;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        margin-top: 2rem;
        width: 100%;

        a {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            transition-duration: 150ms;
            transition-property: color;
            transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
            color: var(--color-muted-foreground-variant);

            &:hover {
                color: var(--color-primary-hover);
            }

            & > span,
            & > i {
                color: currentColor !important;
            }
        }

        & > a {
            cursor: default;
        }

        & > nav {
            display: flex;
            flex-direction: row;
            justify-content: flex-start;
            align-items: flex-start;

            & > a {
                width: 2.5rem;
                height: 2.5rem;
            }
        }
    }

    .license {
        display: flex;
        flex-direction: row;
        justify-content: flex-start;
        align-items: flex-start;
        width: 100%;
        height: 2rem;
        color: light-dark(var(--color-gray-20), var(--color-gray-70));

        & > * {
            color: currentColor;
        }
    }

    @media (width < 40rem) {
        footer {
            height: 10rem;
        }

        .content {
            flex-direction: column;
            justify-content: center;
            gap: 0.5rem;
        }

        .license {
            justify-content: center;
        }
    }
</style>
