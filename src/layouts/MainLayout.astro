---
import Header from "@components/Header.astro";
import Layout from "@layouts/Layout.astro";
import type DefaultProps from "@models/properties";

export interface Props extends DefaultProps {
    title: string;
    description?: string;
    image?: string;
    keywords?: string[];
    floatingHeader?: boolean;
}

const {
    title,
    description,
    image,
    keywords,
    floatingHeader = false,
    id,
    classList,
    class: hashClass,
} = Astro.props;
---

<Layout
    {id}
    {title}
    {description}
    {image}
    {keywords}
    classList={[classList, hashClass]}>
    <Header
        float={floatingHeader}
        transparent={floatingHeader}
        classList={hashClass}
    />
    <slot />
</Layout>
