---
import AdsSection from "@components/Sections/AdsSection.astro";
import CommentsSection from "@components/Sections/CommentsSection.astro";
import ContentSection from "@components/Sections/ContentSection.astro";
import HeaderSection from "@components/Sections/HeaderSection.astro";
import StageSection from "@components/Sections/StageSection.astro";
import MainLayout from "@layouts/MainLayout.astro";
import type DefaultProps from "@models/properties";
import type Travel from "@models/travel";

export interface Props extends DefaultProps, Travel {
    ads?: boolean;
    comments?: boolean;
}

const {
    date,
    title,
    subtitle,
    description,
    image,
    video,
    keywords,
    ads = true,
    comments = false,
    id,
    classList,
    class: hashClass,
} = Astro.props;
---

<MainLayout
    {id}
    {title}
    {description}
    image={image.src}
    {keywords}
    classList={[classList, hashClass]}>
    <HeaderSection {title} {subtitle} {image} />
    <ContentSection>
        <slot />
    </ContentSection>
    {comments && <CommentsSection />}
    {ads && <AdsSection />}
    <StageSection />
</MainLayout>
