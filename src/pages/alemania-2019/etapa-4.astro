export const travel: Travel = {
    date: new Date("2019-08-11"),
    title: "Friburgo, Schiltach, Todtnau...",
    subtitle: "Alemania",
    description:
        "En esta etapa de nuestro viaje a Alemania, llegamos a la hermosa Selva Negra y nos instalamos en el Camping Kirchzarten, cerca de Friburgo. Exploramos la ciudad de Friburgo, con su peculiar restricción de acceso, y aprovechamos el transporte gratuito proporcionado por el camping. Además, visitamos encantadores lugares como Schiltach, Alpirsbach, Triberg, Todtnau, el Lago Titisee y disfrutamos de aventuras como un emocionante descenso en trineo. El viaje nos dejó maravillados por la Selva Negra y sus sorpresas culinarias y culturales.",
    image: new LocalImage(IMG_20190812_447, "Friburgo"),
    video: undefined,
    keywords: [
        "Alemania",
        "Selva Negra",
        "Camping Kirchzarten",
        "Friburgo",
        "Pegatina de acceso",
        "Schiltach",
        "Casco histórico",
        "Alpirsbach",
        "Abadía",
        "Cerveza Alpirsbach",
        "Triberg",
        "Cascadas",
        "Tobogán en Todtnau",
        "Lago Titisee",
        "Tren de cercanías",
        "Transporte gratuito",
        "Experiencia culinaria",
        "Supermercados alemanes",
        "Reciclaje de botellas",
        "Gastronomía local",
        "Paseo en trineo",
        "Maravillosos paisajes",
        "Cultura alemana",
        "Patrimonio histórico",
        "Salchichas alemanas",
    ],
