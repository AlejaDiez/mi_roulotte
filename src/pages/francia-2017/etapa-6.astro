            )}
            class:list={["col-4", "row-6"]}
        />
        <Photo
            image={new LocalImage(IMG_20170823_200247, "Moulin Rouge")}
            class:list={["col-4", "row-3"]}
        />

        <Photo
            image={new LocalImage(IMG_20170822_150919, "Arco del triunfo")}
            class:list={["col-8", "row-6"]}
        />
        <Photo
