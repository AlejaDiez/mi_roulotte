---
import Photo from "@components/Photo.astro";
import Layout from "@layouts/Layout.astro";
import { LocalImage, RemoteImage } from "@models/image";

import IMG_20200825_185010 from "@assets/IMG_20200825_185010.jpg";
---

<Layout
    title="Mi Roulotte"
    description="Disfruta de los emocionantes viajes en familia que hemos realizado con nuestra caravana. Explora nuevos lugares, crea recuerdos inolvidables y vive la libertad en la carretera. ¡Nos vemos en la carretera!"
    image="/images/miroulotte.png"
    keywords={[
        "mi roulotte",
        "miroulotte.es",
        "caravana",
        "knaus",
        "camping",
        "viajes",
        "europa",
        "alemania",
        "francia",
        "españa",
        "portugal",
        "paises bajos",
        "holanda",
        "belgica",
        "italia",
        "brico caravana",
        "brico-cv",
        "bricolaje",
    ]}>
    <Photo image={new LocalImage(IMG_20200825_185010, "Local Image")} />
    <br />
    <Photo
        image={new RemoteImage(
            "https://picsum.photos/1024/1024?random=410055",
            1024,
            1024,
            "Remote Image"
        )}
    />
</Layout>
